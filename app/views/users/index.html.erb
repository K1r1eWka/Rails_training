<h1>All Bloggers</h1>
<% @users.each do |user|%>
    <div style="display: flex; flex-direction: column; align-items: center; background-color: lightgray; border-radius: 10px; margin: 10px 10px;">
        <h3><%= link_to user.username, user_path(user) %></h3>
        <h3><%= link_to gravatar_for(user, size: 150), user_path(user) %></h3>
        <h3><%= pluralize(user.articles.count, "article") %></h3>
        <h3><%= link_to "View profile", user_path(user) %></h3>
        <h3><%= link_to "Edit profile", edit_user_path(user) %></h3>
        <small>Joined <%= time_ago_in_words(user.created_at)%> ago</small>
    </div>
<% end %>