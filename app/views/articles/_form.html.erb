<%= render 'shared/errors', obj: @article%>

<%= form_with model: @article, url: articles_path, local: true do |f| %>
    <p>
        <%= f.label :title %><br>
        <%= f.text_field :title %>
    </p>
    <p>
        <%= f.label :description %><br>
        <%= f.text_area :description %>
    </p>
    <p>
        <%= f.submit "Create Article" %>
    </p>
<% end %>